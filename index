// CANVAS FIREWORKS EFFECT BACKGROUND
const canvas = document.getElementById('fw-canvas');
const cx = canvas.getContext('2d');
let rockets = [], parts = [];
function resize(){ canvas.width=window.innerWidth; canvas.height=window.innerHeight; }
window.addEventListener('resize', resize); resize();

function rnd(min, max){ return Math.random()*(max-min)+min; }
function launch(){
  if(rockets.length < 3) {
    rockets.push({
      x: rnd(canvas.width*0.1, canvas.width*0.9), y: canvas.height,
      vx: rnd(-1.5, 1.5), vy: rnd(-11, -7),
      c: `hsl(${rnd(0,360)}, 100%, 65%)`, trail: []
    });
  }
}
function burst(x, y, c){
  for(let i=0; i<35; i++){
    let a = rnd(0, Math.PI*2), s = rnd(1, 5);
    parts.push({
      x, y, vx: Math.cos(a)*s, vy: Math.sin(a)*s,
      r: rnd(1, 2.5), alpha: 1, decay: rnd(0.015, 0.03), gravity: 0.06, c
    });
  }
}
function frame(){
  cx.fillStyle = 'rgba(4,6,14,0.2)';
  cx.fillRect(0, 0, canvas.width, canvas.height);
  
  rockets.forEach((r, i)=>{
    r.trail.push({x: r.x, y: r.y});
    if(r.trail.length > 8) r.trail.shift();
    cx.beginPath();
    r.trail.forEach((t, j)=>{
      if(j===0) cx.moveTo(t.x, t.y); else cx.lineTo(t.x, t.y);
    });
    cx.strokeStyle = r.c; cx.lineWidth = 1.5; cx.stroke();
    r.x += r.vx; r.y += r.vy; r.vy += 0.18;
    if(r.vy >= rnd(-0.5, 0.5)){ burst(r.x, r.y, r.c); rockets.splice(i, 1); }
  });
  
  for(let i=parts.length-1; i>=0; i--){
    const p = parts[i]; p.x += p.vx; p.y += p.vy; p.vy += p.gravity; p.vx *= 0.97; p.alpha -= p.decay;
    if(p.alpha<=0){ parts.splice(i, 1); continue; }
    cx.globalAlpha = p.alpha; cx.beginPath(); cx.arc(p.x, p.y, p.r, 0, Math.PI*2); cx.fillStyle = p.c; cx.fill();
  }
  cx.globalAlpha = 1; requestAnimationFrame(frame);
}
frame(); setInterval(launch, 900);
</script>
