// LOGIC KHẤU TRỪ TIỀN KHI MUA HÀNG (YÊU CẦU NẠP TRƯỚC)
// ═══════════════════════════════════════════════════
function openBuyModal(idx){
  if(!currentUser){
    openAuth('login');
    return;
  }
  const p = PRODUCTS[currentCat].items[idx];
  const bal = currentUser.balance || 0;
  const after = bal - p.price;
  
  document.getElementById('modal-pname').textContent = p.name;
  document.getElementById('modal-pprice').textContent = fmt(p.price);
  document.getElementById('modal-balance').textContent = fmt(bal);
  
  const afterEl = document.getElementById('modal-after');
  afterEl.textContent = fmt(Math.max(0, after));
  afterEl.style.color = after < 0 ? 'var(--accent2)' : 'var(--green)';
  
  pendingBuy = { idx, cat: currentCat };
  document.getElementById('buyModal').classList.add('open');
}

function closeBuyModal(){
  document.getElementById('buyModal').classList.remove('open');
  pendingBuy = null;
}

function confirmBuy(){
  if(!pendingBuy || !currentUser) { closeBuyModal(); return; }
  const p = PRODUCTS[pendingBuy.cat].items[pendingBuy.idx];
  const users = getUsers();
  const dbUser = users.find(u => u.id === currentUser.id);
  
  // KIỂM TRA SỐ DƯ TÀI KHOẢN TRƯỚC KHI TRỪ TIỀN
  if(!dbUser || dbUser.balance < p.price){
    closeBuyModal();
    // Thông báo lỗi số dư ví không đủ theo đúng yêu cầu
    showGlobalMsg('❌ Số dư tài khoản không đủ để mua sản phẩm này! Vui lòng nạp thêm tiền để tiếp tục.','error');
    alert('❌ Số dư tài khoản không đủ! Vui lòng bấm vào nút NẠP TIỀN.');
    return;
  }
  
  // Thực hiện trừ tiền trực tiếp vào tài khoản
  dbUser.balance -= p.price;
  if(!dbUser.purchase_history) dbUser.purchase_history = [];
  dbUser.purchase_history.push({
    name: p.name,
    price: p.price,
    time: new Date().toLocaleString('vi-VN'),
    link: p.link
  });
  
  // Đồng bộ lại dữ liệu cục bộ và phiên hiện tại
  saveUsers(users);
  currentUser = dbUser;
  saveUser(dbUser);
  
  closeBuyModal();
  renderNav();
  
  // Hiển thị giao diện download file thành công luôn
  document.getElementById('suc-name').textContent = p.name;
  document.getElementById('suc-link').textContent = p.link;
  document.getElementById('suc-balance').textContent = fmt(currentUser.balance);
  document.getElementById('suc-dl-btn').href = p.link;
  document.getElementById('successModal').classList.add('open');
}

