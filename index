    // Giả lập lấy IP ngẫu nhiên của người đăng ký
    const mockIPs = ['27.72.93.12', '14.231.88.41', '171.244.39.115', '115.79.4.201'];
    const userIP = mockIPs[Math.floor(Math.random()*mockIPs.length)];
    
    const newUser = {
      id: 'u_' + Date.now(),
      username: username,
      fullname: fullname,
      email: email,
      password: pass,
      balance: 0, // Đăng ký mới có 0đ, phải nạp tiền trước
      ip: userIP,
      created_at: new Date().toLocaleDateString('vi-VN'),
      purchase_history: []
    };
    
    users.push(newUser);
    saveUsers(users);
    
    currentUser = newUser;
    saveUser(newUser);
    
    // Tắt hiệu ứng tải
    vBox.style.display = 'none';
    btn.disabled = false;
    btn.style.opacity = '1';
    
    renderNav();
    closeAuth();
    showGlobalMsg('✅ Hệ thống đã gửi mã QR kích hoạt tài khoản về Gmail thành công! Đăng ký hoàn tất!','success');
    showPage('dashboard');
  }, 2000);
}

