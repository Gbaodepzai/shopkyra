<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShopKyra.site – Bán File Uy Tín Số 1 Việt Nam</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=Exo+2:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#04060e;--bg2:#080c18;--panel:#0a0f1e;--panel2:#0d1428;
  --border:#1a2a4a;--border2:#243656;
  --accent:#00d4ff;--accent2:#ff3c6e;
  --gold:#ffd700;--green:#00ff88;--purple:#a855f7;--orange:#ff6b35;
  --text:#c8d8f0;--dim:#5a7a9a;--dim2:#3a4a6a;
  --glow:0 0 20px rgba(0,212,255,.4),0 0 40px rgba(0,212,255,.2);
  --glow2:0 0 20px rgba(255,60,110,.4);
  --glowGold:0 0 20px rgba(255,215,0,.4);
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Exo 2',sans-serif;min-height:100vh;overflow-x:hidden;}
body::after{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;background:radial-gradient(ellipse 60% 40% at 20% 10%,rgba(0,212,255,.06) 0%,transparent 60%),radial-gradient(ellipse 50% 35% at 80% 90%,rgba(255,60,110,.05) 0%,transparent 55%),radial-gradient(ellipse 40% 30% at 50% 50%,rgba(255,215,0,.03) 0%,transparent 50%);}
#fw-canvas{position:fixed;inset:0;z-index:1;pointer-events:none;}

/* ── WELCOME MODAL ── */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;z-index:9999;animation:fadeInOv .4s ease;}
@keyframes fadeInOv{from{opacity:0}to{opacity:1}}
.modal-box{width:100%;max-width:520px;background:linear-gradient(145deg,#0a0f1e,#0f1932);border:1px solid var(--accent);box-shadow:0 0 80px rgba(0,212,255,.3);margin:16px;overflow:hidden;animation:slideUp .5s cubic-bezier(.175,.885,.32,1.275);}
@keyframes slideUp{from{transform:translateY(60px) scale(.9);opacity:0}to{transform:none;opacity:1}}
.mbox-top{background:linear-gradient(135deg,#0050aa,#003377);padding:22px 28px;text-align:center;border-bottom:2px solid var(--accent);}
.mbox-top .mt{font-family:'Orbitron',monospace;font-size:15px;font-weight:900;color:#fff;letter-spacing:4px;}
.mbox-top .ms{font-size:11px;color:rgba(255,255,255,.7);letter-spacing:2px;margin-top:5px;}
.mbox-body{padding:28px 32px;}
.mad{font-family:'Orbitron',monospace;font-size:22px;font-weight:900;color:var(--gold);text-align:center;text-shadow:0 0 30px rgba(255,215,0,.6);margin-bottom:14px;letter-spacing:2px;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{text-shadow:0 0 20px rgba(255,215,0,.5)}50%{text-shadow:0 0 40px rgba(255,215,0,.9),0 0 80px rgba(255,215,0,.4)}}
.mdesc{font-size:14px;line-height:1.9;color:var(--text);text-align:center;margin-bottom:20px;}
.mcontact-box{background:#0a0f1e;border:1px solid var(--border2);padding:14px 18px;margin-bottom:20px;border-radius:4px;}
.mcontact-box p{font-size:13px;line-height:2;color:var(--dim);}
.mcontact-box strong{color:var(--accent);}
.mclose{display:block;width:100%;padding:15px;background:linear-gradient(135deg,var(--accent),#005f99);border:none;color:#000;font-family:'Orbitron',monospace;font-size:11px;font-weight:900;cursor:pointer;letter-spacing:3px;transition:all .3s;}
.mclose:hover{background:linear-gradient(135deg,#00eeff,#0088cc);box-shadow:var(--glow);}

/* ── BUY MODAL ── */
.buy-modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:9000;}
.buy-modal-ov.open{display:flex;}
.buy-modal-box{width:100%;max-width:480px;background:linear-gradient(145deg,#0a0f1e,#0f1932);border:1px solid var(--border2);margin:16px;overflow:hidden;animation:slideUp .4s ease;}
.buy-modal-top{background:linear-gradient(135deg,#1a0a2e,#0d0820);padding:18px 24px;border-bottom:1px solid var(--border2);}
.buy-modal-top h2{font-family:'Orbitron',monospace;font-size:13px;font-weight:900;color:var(--accent);letter-spacing:3px;}
.buy-modal-body{padding:24px;}
.buy-info-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);}
.buy-info-row:last-of-type{border-bottom:none;}
.buy-info-row .label{font-size:13px;color:var(--dim);}
.buy-info-row .val{font-size:14px;font-weight:700;color:var(--text);}
.buy-confirm-btn{display:block;width:100%;padding:14px;background:linear-gradient(135deg,var(--green),#009944);border:none;color:#000;font-family:'Orbitron',monospace;font-size:11px;font-weight:900;cursor:pointer;letter-spacing:2px;margin-top:18px;transition:all .3s;}
.buy-confirm-btn:hover{box-shadow:0 0 20px rgba(0,255,136,.4);}
.buy-cancel-btn{display:block;width:100%;padding:10px;background:transparent;border:1px solid var(--border2);color:var(--dim);font-family:'Orbitron',monospace;font-size:10px;cursor:pointer;letter-spacing:2px;margin-top:8px;transition:all .3s;}
.buy-cancel-btn:hover{border-color:var(--accent2);color:var(--accent2);}

/* ── NAP TIEN MODAL ── */
.nap-modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:9000;}
.nap-modal-ov.open{display:flex;}
.nap-modal-box{width:100%;max-width:520px;background:linear-gradient(145deg,#0a0f1e,#0f1932);border:1px solid var(--accent);box-shadow:0 0 60px rgba(0,212,255,.3);margin:16px;overflow:hidden;animation:slideUp .4s ease;max-height:90vh;overflow-y:auto;}
.nap-modal-top{background:linear-gradient(135deg,#003366,#001a44);padding:20px 28px;border-bottom:2px solid var(--accent);text-align:center;}
.nap-modal-top h2{font-family:'Orbitron',monospace;font-size:14px;font-weight:900;color:var(--accent);letter-spacing:3px;}
.nap-modal-body{padding:28px;}
.nap-step{margin-bottom:28px;}
.nap-step-title{font-family:'Orbitron',monospace;font-size:11px;font-weight:900;color:var(--gold);letter-spacing:2px;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.fg{margin-bottom:16px;}
.fg label{display:block;font-size:12px;color:var(--dim);letter-spacing:1px;margin-bottom:7px;font-family:'Orbitron',monospace;}
.fg input,.fg select{width:100%;background:#060a12;border:1px solid var(--border2);color:var(--text);padding:12px 16px;font-family:'Exo 2',sans-serif;font-size:14px;outline:none;transition:border-color .25s;}
.fg input:focus,.fg select:focus{border-color:var(--accent);}
.fg select option{background:#060a12;}
.amount-presets{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px;}
.amount-btn{padding:10px;border:1px solid var(--border2);background:transparent;color:var(--text);font-family:'Exo 2',sans-serif;font-size:13px;font-weight:700;cursor:pointer;transition:all .25s;}
.amount-btn:hover,.amount-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,.06);}
.sbtn{display:block;width:100%;padding:14px;border:none;font-family:'Orbitron',monospace;font-size:11px;font-weight:900;cursor:pointer;letter-spacing:3px;transition:all .3s;}
.sbtn.cyan{background:linear-gradient(135deg,var(--accent),#005599);color:#000;}
.sbtn.cyan:hover{box-shadow:var(--glow);}
.sbtn.gold{background:linear-gradient(135deg,var(--gold),#aa7700);color:#000;}
.bank-info-box{background:#060a12;border:1px solid var(--accent);padding:20px;margin-top:20px;text-align:center;}
.bank-info-box .bank-row{font-size:14px;line-height:2.2;color:var(--text);}
.bank-info-box .bank-row b{color:var(--gold);}
.bank-info-box .bank-row b.acc{color:var(--accent2);}
.qr-code-img{width:240px;max-width:100%;background:white;padding:8px;border:4px solid var(--accent);margin:16px auto;display:block;}
.nap-content-code{background:#000;border:1px solid var(--accent);font-family:'Orbitron',monospace;font-size:15px;color:var(--green);padding:14px;text-align:center;word-break:break-all;margin-top:10px;cursor:pointer;transition:all .3s;letter-spacing:2px;}
.nap-content-code:hover{background:rgba(0,212,255,.05);}
.copy-hint{font-size:11px;color:var(--dim);text-align:center;margin-top:6px;}
.wait-box{background:rgba(0,212,255,.04);border:1px solid var(--accent);padding:20px;text-align:center;margin-top:20px;}
.wait-spinner{display:inline-block;width:24px;height:24px;border:3px solid rgba(0,212,255,.2);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin-bottom:10px;}
@keyframes spin{to{transform:rotate(360deg)}}
.wait-note{font-size:13px;color:var(--dim);line-height:1.8;margin-top:8px;}
.nap-close-btn{display:block;width:100%;padding:12px;background:transparent;border:1px solid var(--border2);color:var(--dim);font-family:'Orbitron',monospace;font-size:10px;cursor:pointer;letter-spacing:2px;margin-top:12px;transition:all .3s;}
.nap-close-btn:hover{border-color:var(--accent2);color:var(--accent2);}

/* ── LOGIN/REGISTER MODAL ── */
.auth-modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:9000;}
.auth-modal-ov.open{display:flex;}
.auth-modal-box{width:100%;max-width:460px;background:linear-gradient(145deg,#0a0f1e,#0f1932);border:1px solid var(--border2);margin:16px;overflow:hidden;animation:slideUp .4s ease;max-height:92vh;overflow-y:auto;}
.auth-modal-top{background:linear-gradient(135deg,#1a0a2e,#0d0820);padding:18px 24px;border-bottom:1px solid var(--border2);display:flex;align-items:center;justify-content:space-between;}
.auth-modal-top h2{font-family:'Orbitron',monospace;font-size:13px;font-weight:900;color:var(--accent);letter-spacing:3px;}
.auth-close{background:none;border:none;color:var(--dim);font-size:20px;cursor:pointer;padding:0 4px;}
.auth-close:hover{color:var(--accent2);}
.auth-modal-body{padding:28px;}
.auth-tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:24px;}
.auth-tab{flex:1;padding:12px;background:none;border:none;color:var(--dim);font-family:'Orbitron',monospace;font-size:10px;letter-spacing:2px;cursor:pointer;border-bottom:2px solid transparent;transition:all .3s;}
.auth-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.auth-form{display:none;}
.auth-form.active{display:block;}
.auth-msg{padding:10px 14px;margin-bottom:14px;font-size:13px;font-weight:600;border-left:3px solid;}
.auth-msg.error{background:rgba(255,60,110,.07);border-color:var(--accent2);color:var(--accent2);}
.auth-msg.success{background:rgba(0,255,136,.07);border-color:var(--green);color:var(--green);}

/* ── PURCHASE SUCCESS MODAL ── */
.success-modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.92);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;z-index:9500;}
.success-modal-ov.open{display:flex;}
.success-modal-box{width:100%;max-width:500px;background:linear-gradient(145deg,#0a0f1e,#0f1932);border:1px solid var(--green);box-shadow:0 0 80px rgba(0,255,136,.3);margin:16px;overflow:hidden;animation:slideUp .5s ease;}
.success-top{background:linear-gradient(135deg,#003322,#001a11);padding:20px 28px;text-align:center;border-bottom:2px solid var(--green);}
.success-top h2{font-family:'Orbitron',monospace;font-size:14px;font-weight:900;color:var(--green);letter-spacing:3px;}
.success-body{padding:28px;}
.success-item{background:#060a12;border:1px solid var(--border2);padding:16px;margin-bottom:16px;}
.success-item .si-label{font-size:11px;color:var(--dim);letter-spacing:1px;margin-bottom:6px;}
.success-item .si-val{font-size:15px;font-weight:700;color:var(--text);}
.success-item .si-val.link{color:var(--accent);word-break:break-all;font-size:13px;}
.success-dl-btn{display:block;width:100%;padding:15px;background:linear-gradient(135deg,var(--green),#009944);border:none;color:#000;font-family:'Orbitron',monospace;font-size:12px;font-weight:900;cursor:pointer;letter-spacing:2px;text-decoration:none;text-align:center;margin-top:8px;}

/* ── BANNER ── */
.ad-banner{background:linear-gradient(90deg,#ff3c6e,#ff6b35,#ffd700,#00ff88,#00d4ff,#ffd700,#ff6b35,#ff3c6e);background-size:400% 100%;animation:gradShift 4s ease infinite;text-align:center;padding:10px 20px;font-family:'Orbitron',monospace;font-size:11px;font-weight:900;color:#000;letter-spacing:3px;position:relative;z-index:200;}
@keyframes gradShift{0%{background-position:0 50%}50%{background-position:100% 50%}100%{background-position:0 50%}}

/* ── NAV ── */
nav{position:sticky;top:0;z-index:500;display:flex;align-items:center;justify-content:space-between;padding:10px 32px;background:rgba(4,6,14,.97);border-bottom:1px solid var(--border2);backdrop-filter:blur(20px);gap:12px;flex-wrap:wrap;}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
.logo img{width:42px;height:42px;border-radius:50%;object-fit:cover;border:2px solid var(--accent);box-shadow:var(--glow);transition:transform .3s;}
.logo:hover img{transform:rotate(10deg) scale(1.1);}
.logo-text{font-family:'Orbitron',monospace;font-size:20px;font-weight:900;color:var(--accent);letter-spacing:2px;animation:logoBounce 1.8s cubic-bezier(.36,.07,.19,.97) infinite;text-shadow:var(--glow),0 0 40px rgba(0,212,255,.3);}
@keyframes logoBounce{0%{transform:translateY(0)}10%{transform:translateY(-8px) rotate(-2deg) scale(1.06)}40%{transform:translateY(-16px) rotate(1.5deg) scale(1.1)}70%{transform:translateY(-4px)}100%{transform:translateY(0)}}
.logo-text span{color:var(--accent2);}
.nav-right{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.nbtn{padding:8px 18px;border:1px solid var(--border2);background:transparent;color:var(--text);font-family:'Exo 2',sans-serif;font-size:13px;font-weight:700;letter-spacing:1px;cursor:pointer;text-decoration:none;transition:all .25s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);white-space:nowrap;}
.nbtn:hover{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,.06);}
.nbtn.blue{background:linear-gradient(135deg,var(--accent),#005599);border-color:var(--accent);color:#000;font-weight:900;}
.nbtn.gold{background:linear-gradient(135deg,var(--gold),#aa7700);border-color:var(--gold);color:#000;font-weight:900;}
.nbtn.green{background:linear-gradient(135deg,var(--green),#009944);border-color:var(--green);color:#000;font-weight:900;}
.nbtn.red{background:linear-gradient(135deg,var(--accent2),#7a0820);border-color:var(--accent2);color:#fff;}
.uchip{display:flex;align-items:center;gap:10px;background:var(--panel);border:1px solid var(--border2);padding:7px 16px;}
.uchip .un{font-family:'Orbitron',monospace;font-size:10px;color:var(--accent);letter-spacing:1px;}
.uchip .ub{font-family:'Orbitron',monospace;font-size:11px;color:var(--gold);font-weight:700;}

/* ── MARQUEE ── */
.marquee-bar{background:linear-gradient(90deg,var(--panel),var(--panel2),var(--panel));border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:10px 0;overflow:hidden;white-space:nowrap;}
.marquee-inner{display:inline-block;animation:marquee 28s linear infinite;font-size:13px;color:var(--dim);letter-spacing:1px;}
@keyframes marquee{from{transform:translateX(100vw)}to{transform:translateX(-100%)}}
.marquee-inner span{color:var(--accent);font-weight:700;}

/* ── LAYOUT ── */
.wrap{position:relative;z-index:50;max-width:1180px;margin:0 auto;padding:30px 18px 100px;}
.msg{padding:13px 18px;margin-bottom:20px;font-size:14px;font-weight:600;border-left:4px solid;}
.msg.success{background:rgba(0,255,136,.07);border-color:var(--green);color:var(--green);}
.msg.error{background:rgba(255,60,110,.07);border-color:var(--accent2);color:var(--accent2);}
.fade-in{animation:fadeIn .5s ease both;}
@keyframes fadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}

/* ── HERO ── */
.hero{text-align:center;padding:60px 20px 36px;}
.hero-badge{display:inline-block;background:linear-gradient(135deg,rgba(255,215,0,.15),rgba(255,215,0,.05));border:1px solid rgba(255,215,0,.4);color:var(--gold);font-family:'Orbitron',monospace;font-size:10px;font-weight:900;letter-spacing:4px;padding:7px 20px;margin-bottom:20px;}
.hero h1{font-family:'Orbitron',monospace;font-size:clamp(24px,5vw,52px);font-weight:900;line-height:1.15;margin-bottom:16px;background:linear-gradient(135deg,#ffffff 0%,var(--accent) 50%,var(--accent2) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.hero p{font-size:clamp(14px,2vw,18px);color:var(--dim);max-width:680px;margin:0 auto 30px;}
.hero-stats{display:flex;gap:32px;justify-content:center;flex-wrap:wrap;}
.hstat-num{font-family:'Orbitron',monospace;font-size:28px;font-weight:900;color:var(--accent);line-height:1;}
.hstat-label{font-size:11px;color:var(--dim);letter-spacing:2px;margin-top:4px;text-transform:uppercase;}
.hero-btns{margin-top:30px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.hbtn{padding:14px 32px;font-family:'Orbitron',monospace;font-size:11px;font-weight:900;letter-spacing:3px;cursor:pointer;text-decoration:none;border:none;clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);transition:all .3s;}
.hbtn.main{background:linear-gradient(135deg,var(--accent),#005599);color:#000;}
.hbtn.main:hover{box-shadow:var(--glow);transform:translateY(-2px);}
.hbtn.sec{background:transparent;border:1px solid var(--border2);color:var(--text);}
.hbtn.sec:hover{border-color:var(--accent2);color:var(--accent2);}

/* ── INFO CARDS ── */
.info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;}
.info-card{background:var(--panel);border:1px solid var(--border);padding:24px;transition:border-color .3s;}
.info-card:hover{border-color:var(--accent);}
.info-card-icon{font-size:32px;margin-bottom:12px;}
.info-card-title{font-family:'Orbitron',monospace;font-size:11px;font-weight:900;color:#fff;letter-spacing:2px;margin-bottom:8px;}
.info-card-desc{font-size:13px;color:var(--dim);line-height:1.7;}
.sec-title{font-family:'Orbitron',monospace;font-size:13px;font-weight:900;color:#fff;margin-bottom:18px;display:flex;align-items:center;gap:14px;letter-spacing:2px;}

/* ── CATEGORY TABS ── */
.cat-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px;}
.cat-tab{padding:10px 20px;border:1px solid var(--border2);background:transparent;color:var(--dim);font-family:'Orbitron',monospace;font-size:10px;letter-spacing:2px;cursor:pointer;transition:all .25s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
.cat-tab:hover,.cat-tab.active{border-color:var(--accent);color:var(--accent);background:rgba(0,212,255,.06);}
.cat-tab.active.gold-tab{border-color:var(--gold);color:var(--gold);background:rgba(255,215,0,.06);}
.cat-tab.active.orange-tab{border-color:var(--orange);color:var(--orange);background:rgba(255,107,53,.06);}

/* ── PRODUCT GRID ── */
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px;}
.prod-card{background:var(--panel);border:1px solid var(--border);overflow:hidden;transition:transform .3s,border-color .3s,box-shadow .3s;position:relative;}
.prod-card:hover{transform:translateY(-4px);border-color:var(--accent);box-shadow:var(--glow);}
.prod-img{width:100%;height:160px;object-fit:cover;display:block;}
.prod-tag{position:absolute;top:12px;right:12px;padding:4px 10px;font-family:'Orbitron',monospace;font-size:9px;font-weight:900;letter-spacing:1px;}
.prod-tag.red{background:var(--accent2);color:#fff;}
.prod-tag.gold{background:var(--gold);color:#000;}
.prod-tag.cyan{background:var(--accent);color:#000;}
.prod-tag.green{background:var(--green);color:#000;}
.prod-tag.orange{background:var(--orange);color:#fff;}
.prod-body{padding:16px;}
.prod-name{font-family:'Orbitron',monospace;font-size:12px;font-weight:900;color:#fff;margin-bottom:6px;letter-spacing:1px;}
.prod-desc{font-size:12px;color:var(--dim);line-height:1.6;margin-bottom:12px;}
.prod-price{font-family:'Orbitron',monospace;font-size:16px;font-weight:900;color:var(--gold);margin-bottom:12px;text-shadow:var(--glowGold);}
.prod-btns{display:flex;gap:8px;flex-wrap:wrap;}
.pbtn{padding:8px 14px;border:none;font-family:'Orbitron',monospace;font-size:9px;font-weight:900;cursor:pointer;letter-spacing:1px;transition:all .3s;text-decoration:none;display:inline-block;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);}
.pbtn.buy{background:linear-gradient(135deg,var(--accent),#005599);color:#000;}
.pbtn.buy:hover{box-shadow:var(--glow);}
.pbtn.video{background:transparent;border:1px solid var(--border2);color:var(--dim);}
.pbtn.video:hover{border-color:var(--gold);color:var(--gold);}
.locked-overlay{position:absolute;inset:0;background:rgba(4,6,14,.75);backdrop-filter:blur(2px);display:flex;align-items:center;justify-content:center;}
.locked-msg{text-align:center;}
.locked-msg p{font-family:'Orbitron',monospace;font-size:10px;color:var(--dim);letter-spacing:2px;margin-bottom:10px;}

/* ── TX SECTION ── */
.tx-section{background:var(--panel);border:1px solid var(--border);}
.tx-section-title{font-family:'Orbitron',monospace;font-size:11px;font-weight:900;color:var(--accent);letter-spacing:3px;padding:14px 18px;border-bottom:1px solid var(--border);}
.tx-feed{max-height:200px;overflow:hidden;}
.recent-item{padding:9px 18px;border-bottom:1px solid var(--border);font-size:13px;color:var(--dim);animation:fadeIn .3s ease;}
.tx-name{color:var(--text);font-weight:700;}
.tx-amt{color:var(--green);font-weight:700;}
.tx-buy-feed{max-height:280px;overflow-y:auto;}
.buy-tx-item{display:flex;align-items:center;gap:14px;padding:10px 18px;border-bottom:1px solid var(--border);}
.btx-icon{font-size:18px;width:28px;text-align:center;}
.btx-info{flex:1;}
.btx-name{display:block;font-size:13px;font-weight:700;color:var(--text);}
.btx-prod{display:block;font-size:11px;color:var(--dim);}
.btx-price{font-family:'Orbitron',monospace;font-size:12px;color:var(--gold);font-weight:900;}

/* ── CONTACT / POLICY ── */
.page-panel{background:var(--panel);border:1px solid var(--border);padding:32px;max-width:800px;margin:0 auto;}
.page-panel h2{font-family:'Orbitron',monospace;font-size:16px;color:var(--accent);letter-spacing:3px;margin-bottom:24px;padding-bottom:14px;border-bottom:1px solid var(--border2);}
.page-panel p,.page-panel li{font-size:14px;color:var(--dim);line-height:2;margin-bottom:8px;}
.page-panel strong{color:var(--text);}
.contact-item{display:flex;align-items:center;gap:16px;padding:16px;background:#060a12;border:1px solid var(--border2);margin-bottom:12px;transition:border-color .3s;}
.contact-item:hover{border-color:var(--accent);}
.contact-icon{font-size:28px;width:40px;text-align:center;}
.contact-label{font-size:11px;color:var(--dim);letter-spacing:1px;}
.contact-val{font-size:15px;font-weight:700;color:var(--text);}
.contact-val a{color:var(--accent);text-decoration:none;}
.contact-val a:hover{text-decoration:underline;}

/* ── DASHBOARD ── */
.dash-layout{display:grid;grid-template-columns:220px 1fr;gap:24px;}
.dash-sidebar{background:var(--panel);border:1px solid var(--border);padding:0;overflow:hidden;}
.dash-sidebar a{display:block;padding:14px 20px;text-decoration:none;color:var(--dim);font-size:13px;border-bottom:1px solid var(--border);transition:all .25s;}
.dash-sidebar a:hover,.dash-sidebar a.active{background:rgba(0,212,255,.06);color:var(--accent);border-left:3px solid var(--accent);}
.dash-main{display:flex;flex-direction:column;gap:20px;}
.dc{background:var(--panel);border:1px solid var(--border);padding:24px;}
.dc h3{font-family:'Orbitron',monospace;font-size:12px;color:var(--accent);letter-spacing:2px;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border);}
.dc p{font-size:14px;color:var(--dim);padding:8px 0;border-bottom:1px solid rgba(26,42,74,.5);line-height:1.7;}
.dc p:last-child{border-bottom:none;}
.dc p strong{color:var(--text);}

/* ── ADMIN TABLE ── */
.admin-table-wrapper{overflow-x:auto;margin-top:14px;}
.admin-table{width:100%;border-collapse:collapse;font-size:13px;color:var(--text);text-align:left;}
.admin-table th{background:var(--panel2);border:1px solid var(--border2);padding:10px 14px;color:var(--accent);font-family:'Orbitron',monospace;}
.admin-table td{border:1px solid var(--border);padding:10px 14px;background:#050914;}
.admin-table tr:hover td{background:rgba(0,212,255,.03);}

/* ── STORAGE ── */
.storage-item{background:#060a12;border:1px solid var(--border2);padding:16px;margin-bottom:12px;}
.storage-item-name{font-family:'Orbitron',monospace;font-size:11px;color:var(--gold);letter-spacing:1px;margin-bottom:8px;}
.storage-item-time{font-size:11px;color:var(--dim);margin-bottom:10px;}
.storage-btns{display:flex;gap:8px;flex-wrap:wrap;}

/* ── FOOTER ── */
footer{position:relative;z-index:50;background:var(--panel2);border-top:1px solid var(--border);padding:32px 20px;text-align:center;}
.footer-logo{font-family:'Orbitron',monospace;font-size:22px;font-weight:900;color:var(--accent);letter-spacing:2px;display:block;margin-bottom:16px;}
.footer-logo span{color:var(--accent2);}
.footer-links{display:flex;gap:20px;justify-content:center;flex-wrap:wrap;margin-bottom:16px;}
.footer-links a{text-decoration:none;color:var(--dim);font-size:13px;transition:color .25s;}
.footer-links a:hover{color:var(--accent);}
.footer-socials{display:flex;gap:12px;justify-content:center;margin-bottom:16px;}
.social-btn{padding:8px 18px;background:var(--panel);border:1px solid var(--border2);text-decoration:none;font-size:13px;transition:all .25s;}
.social-btn:hover{border-color:var(--accent);}
footer p{font-size:12px;color:var(--dim2);}

/* ── ZALO FLOAT ── */
.zalo-float{position:fixed;bottom:24px;right:24px;z-index:9000;display:flex;flex-direction:column;gap:10px;align-items:flex-end;}
.zalo-float-btn{display:flex;align-items:center;gap:10px;padding:10px 18px;border-radius:50px;text-decoration:none;font-weight:700;font-size:13px;color:#fff;transition:all .3s;box-shadow:0 4px 20px rgba(0,0,0,.4);}
.zalo-float-btn.ktv{background:linear-gradient(135deg,#0068ff,#0050cc);}
.zalo-float-btn.dev{background:linear-gradient(135deg,#7c3aed,#5b21b6);}
.zalo-float-btn:hover{transform:translateY(-3px) scale(1.04);}
.zalo-float-label{font-size:10px;opacity:.8;display:block;}

/* ── MOBILE ── */
@media(max-width:768px){
  nav{padding:10px 16px;}
  .wrap{padding:20px 12px 80px;}
  .dash-layout{grid-template-columns:1fr;}
  .prod-grid{grid-template-columns:repeat(auto-fill,minmax(200px,1fr));}
  .nap-modal-box,.auth-modal-box,.modal-box,.buy-modal-box,.success-modal-box{margin:10px;}
  .mbox-body,.auth-modal-body,.nap-modal-body,.buy-modal-body,.success-body{padding:18px;}
}
</style>
