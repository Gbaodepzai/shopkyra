function doRegister(){
  const fullname = document.getElementById('regFullname').value.trim();
  const username = document.getElementById('regUser').value.trim().toLowerCase();
  const email = document.getElementById('regEmail').value.trim();
  const pass = document.getElementById('regPass').value;
  const confirm = document.getElementById('regPassConfirm').value;
  
  if(!fullname || !username || !email || !pass){
    showAuthMsg('❌ Vui lòng nhập đầy đủ tất cả các trường dữ liệu!');
    return;
  }
  if(username.length < 4){
    showAuthMsg('❌ Tên đăng nhập phải chứa từ 4 ký tự trở lên!');
    return;
  }
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){
    showAuthMsg('❌ Hòm thư Email không đúng định dạng!');
    return;
  }
  if(pass.length < 6){
    showAuthMsg('❌ Mật khẩu bảo mật phải từ 6 ký tự trở lên!');
    return;
  }
  if(pass !== confirm){
    showAuthMsg('❌ Mật khẩu xác nhận lại không trùng khớp!');
    return;
  }
  
  const users = getUsers();
  if(users.find(u=>u.username===username)){
    showAuthMsg('❌ Tên đăng nhập này đã tồn tại trên hệ thống!');
    return;
  }
  
  // Hiển thị hiệu ứng gửi QR kích hoạt về Gmail
  const vBox = document.getElementById('emailQrVerificationBox');
  const btn = document.getElementById('btnSubmitRegister');
  vBox.style.display = 'block';
  btn.disabled = true;
  btn.style.opacity = '0.5';
  
